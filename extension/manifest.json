{
  "manifest_version": 3,
  "name": "SchemeAI Portal Assistant",
  "version": "1.0",
  "description": "Auto-detects government portals and fills your details automatically.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pmkisan.gov.in/*",
        "https://pmaymis.gov.in/*",
        "https://*.gov.in/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
